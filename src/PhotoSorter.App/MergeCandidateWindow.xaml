<Window x:Class="PhotoSorter.App.MergeCandidateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PhotoSorter.App.Controls"
        Title="Merge another suggestion"
        Icon="Assets/PhotoSorter.ico"
        Width="1180"
        Height="780"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="MergeOptionStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Card"
                                Padding="10"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="#B9BDE8" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MergePhotoStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="184" />
            <Setter Property="Height" Value="142" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22,16"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="Merge another suggestion" />
                <TextBlock Margin="0,5,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap">
                    <Run Text="Current group: " />
                    <Run FontWeight="SemiBold"
                         Text="{Binding CurrentCandidate.Title, Mode=OneWay}" />
                    <Run Text=" · " />
                    <Run Text="{Binding CurrentCandidate.Period, Mode=OneWay}" />
                    <Run Text=" · " />
                    <Run Text="{Binding CurrentCandidate.Summary, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="22,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="4,2,4,14">
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="Suggestions" />
                        <TextBlock Margin="0,3,0,0"
                                   Style="{StaticResource CaptionStyle}"
                                   Text="Closest in time first. Select one to inspect its photos."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Options}"
                             ItemContainerStyle="{StaticResource MergeOptionStyle}"
                             SelectedItem="{Binding SelectedOption}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="94" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="84"
                                            Height="66"
                                            HorizontalAlignment="Left"
                                            Background="#E9EBF1"
                                            CornerRadius="8"
                                            ClipToBounds="True">
                                        <controls:LazyThumbnail FilePath="{Binding PreviewBundle.ThumbnailPath}"
                                                                FileLength="{Binding PreviewBundle.ThumbnailLength}"
                                                                LastWriteTimeUtc="{Binding PreviewBundle.ThumbnailLastWriteTimeUtc}"
                                                                PixelSize="160"
                                                                Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Candidate.Title}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Candidate.FullPlaceName}" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding Candidate.Period}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding GapText}" />
                                        <TextBlock Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding Candidate.Summary}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="23"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedOption.Candidate.Title}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding SelectedOption.Candidate.FullPlaceName}" />
                            <TextBlock Margin="0,5,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding SelectedOption.Candidate.Period}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="10,5"
                                VerticalAlignment="Top"
                                Background="{StaticResource AccentSoftBrush}"
                                CornerRadius="9">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="{Binding SelectedOption.GapText}" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,14,0,14"
                            Padding="12,9"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="9">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedOption.Candidate.WhySuggested}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,5,0,0"
                                       Style="{StaticResource CaptionStyle}"
                                       Text="{Binding ResultSummary}" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding SelectedOption.Bundles}"
                             ItemContainerStyle="{StaticResource MergePhotoStyle}"
                             ScrollViewer.CanContentScroll="False"
                             VirtualizingPanel.IsVirtualizing="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button MinHeight="0"
                                        Padding="0"
                                        Background="Transparent"
                                        Click="OnPhotoPreviewClick"
                                        ToolTip="View this photo larger">
                                    <Grid ClipToBounds="True">
                                        <Border Background="#E9EBF1"
                                                CornerRadius="9">
                                            <controls:LazyThumbnail FilePath="{Binding ThumbnailPath}"
                                                                    FileLength="{Binding ThumbnailLength}"
                                                                    LastWriteTimeUtc="{Binding ThumbnailLastWriteTimeUtc}"
                                                                    PixelSize="256"
                                                                    Stretch="UniformToFill" />
                                        </Border>
                                        <Border Height="27"
                                                VerticalAlignment="Bottom"
                                                Background="#B0000000"
                                                CornerRadius="0,0,9,9">
                                            <TextBlock Margin="7,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="White"
                                                       Text="{Binding Captured}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="22,12"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="This only changes the current review. No files move until you choose Name and move."
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Margin="16,0,8,0"
                        IsCancel="True"
                        Content="Cancel" />
                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="OnMergeClick"
                        Content="Merge selected group" />
            </Grid>
        </Border>
    </Grid>
</Window>
