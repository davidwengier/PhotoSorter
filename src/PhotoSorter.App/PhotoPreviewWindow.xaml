<Window x:Class="PhotoSorter.App.PhotoPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PhotoSorter.App.Controls"
        Title="{Binding FileName}"
        Icon="Assets/PhotoSorter.ico"
        Width="1120"
        Height="820"
        MinWidth="720"
        MinHeight="520"
        Background="#15171D"
        PreviewKeyDown="OnPreviewKeyDown"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="74" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="22,12"
                Background="#20232B"
                BorderBrush="#353945"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding FileName}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#B9BECA"
                               Text="{Binding Captured}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button x:Name="PreviousButton"
                            Margin="0,0,8,0"
                            Background="#343844"
                            Foreground="White"
                            Click="OnPreviousClick"
                            Content="Previous"
                            ToolTip="Previous photo (Left arrow)" />
                    <TextBlock x:Name="PositionText"
                               MinWidth="72"
                               Margin="4,0,12,0"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="#B9BECA" />
                    <Button x:Name="NextButton"
                            Margin="0,0,12,0"
                            Background="#343844"
                            Foreground="White"
                            Click="OnNextClick"
                            Content="Next"
                            ToolTip="Next photo (Right arrow)" />
                    <Button Background="#343844"
                            Foreground="White"
                            IsCancel="True"
                            Content="Close" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="20"
                Background="#090A0D"
                CornerRadius="12"
                ClipToBounds="True">
            <controls:LazyThumbnail FilePath="{Binding ThumbnailPath}"
                                    FileLength="{Binding ThumbnailLength}"
                                    LastWriteTimeUtc="{Binding ThumbnailLastWriteTimeUtc}"
                                    PixelSize="1024"
                                    Stretch="Uniform" />
        </Border>

        <Border Grid.Row="2"
                Padding="22,10"
                Background="#20232B"
                BorderBrush="#353945"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="0,0,12,3"
                           Foreground="#B9BECA"
                           Text="Location" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,0,3"
                           Foreground="White"
                           Text="{Binding Location}" />
                <TextBlock Grid.Row="1"
                           Margin="0,0,12,3"
                           Foreground="#B9BECA"
                           Text="Source" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,0,0,3"
                           Foreground="White"
                           Text="{Binding SourceFolder}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding SourceFolder}" />
                <TextBlock Grid.Row="2"
                           Margin="0,0,12,3"
                           Foreground="#B9BECA"
                           Text="Details" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,0,0,3"
                           Foreground="White"
                           Text="{Binding Metadata}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Metadata}" />
                <TextBlock Grid.Row="3"
                           Margin="0,0,12,0"
                           Foreground="#B9BECA"
                           Text="Files" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Foreground="White"
                           Text="{Binding Files}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Files}" />

                <CheckBox Grid.RowSpan="4"
                          Grid.Column="2"
                          Margin="24,0,0,0"
                          VerticalAlignment="Center"
                          FontWeight="SemiBold"
                          Foreground="White"
                          Content="Include in move"
                          IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>
    </Grid>
</Window>
